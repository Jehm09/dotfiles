#!/usr/bin/env bash
# Setup CLI — single entry point for all install and configuration tasks.
#
# Fresh Arch install flow:
#   1. Boot the Arch ISO, clone this repo, run:  setup install
#   2. After first reboot, run:                  setup post
#
# On an existing Arch system:
#   setup desktop    — install the full Hyprland desktop interactively
#   setup dotfiles   — only link ~/.config symlinks
#
# Usage: ./setup <subcommand> [options]

cd "$(dirname "$0")"
REPO_ROOT="$(pwd)"
export REPO_ROOT

source "$REPO_ROOT/lib/utils.sh"

# ------------------------------------------------------------------
# Help
# ------------------------------------------------------------------
_showhelp() {
    cat <<EOF

Setup for the dotfiles system.

Usage: $0 <subcommand> [options]

Subcommands:
    install       Arch Linux install from the live ISO  (run as root)
                  Runs: pacman -Syu → inject packages → archinstall

    post          Post-install setup after first boot  (run as your user)
                  Runs: multilib → paru → AUR packages → hooks → dotfiles → fish

    desktop       Install Hyprland desktop on an existing Arch system
    dotfiles      Link dotfiles to ~/.config (or use --dry-run / --unlink)

Aliases:
    dots          Alias for 'dotfiles'

Examples:
    $0 install                    Full automated Arch install from ISO
    $0 post                       Post-install: AUR, hooks, dotfiles, shell
    $0 desktop                    Interactive component selection
    $0 desktop --all              Install everything non-interactively
    $0 desktop --skip-aur         Skip AUR packages
    $0 dotfiles                   Link dotfiles to ~/.config
    $0 dotfiles --dry-run         Preview what would happen
    $0 dotfiles --unlink          Remove managed symlinks

EOF
}

# ------------------------------------------------------------------
# Subcommand dispatch
# ------------------------------------------------------------------
case "${1:-}" in
    install)
        shift
        if [[ "$EUID" -ne 0 ]]; then
            error "'setup install' must run as root from the Arch live ISO."
            exit 1
        fi
        bash "$REPO_ROOT/cmd/arch/install.sh" "$@"
        ;;

    post)
        shift
        prevent_root
        bash "$REPO_ROOT/cmd/arch/post-install.sh" "$@"
        ;;

    desktop)
        shift
        prevent_root
        source "$REPO_ROOT/cmd/desktop.sh" "$@"
        ;;

    dotfiles|dots)
        shift
        bash "$REPO_ROOT/lib/symlink.sh" "$@"
        ;;

    ""|-h|--help|help)
        _showhelp
        ;;

    *)
        error "Unknown subcommand: $1"
        _showhelp
        exit 1
        ;;
esac
